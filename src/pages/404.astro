---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found | GetEmoji.Online"
  description="The page you're looking for doesn't exist. Browse our emoji collection instead."
>
  <div class="max-w-6xl mx-auto px-4 py-24 text-center">
    <div class="text-8xl mb-8 floating">😕</div>
    <h1 class="text-6xl font-black mb-4 uppercase">404</h1>
    <p class="text-xl text-gray-500 mb-4">This emoji doesn't exist (yet!)</p>
    <p class="text-gray-400 mb-8">The page you're looking for was moved or never existed.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="inline-block px-10 py-4 bg-yellow-400 font-black rounded-xl uppercase hover:bg-yellow-500 transition-all shadow-lg">Go Home</a>
      <a href="/smileys/" class="inline-block px-10 py-4 bg-slate-900 text-white font-black rounded-xl uppercase hover:bg-black transition-all shadow-lg">Browse Emojis</a>
    </div>
  </div>

  <style>
    .floating {
      animation: float 3s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }
  </style>
</BaseLayout>
